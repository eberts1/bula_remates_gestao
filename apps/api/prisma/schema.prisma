generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



enum TenantRole {

  owner

  admin

  member

  viewer

}



enum DocumentStatus {

  draft

  ready

  deleted

}



enum ClientFormTokenType {

  create

  edit

}



enum ClientExportPurpose {

  message_dispatcher

  requested_listing

  internal

  other

}



model User {

  id           String   @id @default(uuid()) @db.Uuid

  email        String   @unique

  passwordHash String   @map("password_hash")

  name         String

  createdAt    DateTime @default(now()) @map("created_at")

  updatedAt    DateTime @updatedAt @map("updated_at")

  deletedAt    DateTime? @map("deleted_at")

  isSuperAdmin Boolean  @default(false) @map("is_super_admin")



  memberships    TenantMember[]

  documents         Document[]

  collaborators     Collaborator[]

  clientFormTokens  ClientFormToken[]

  clientImportBatches ClientImportBatch[]

  clientExportBatches ClientExportBatch[]

  auditLogs         AuditLog[]

  attendanceBoardColumns AttendanceBoardColumn[]
  attendanceActions      AttendanceAction[]
  attendanceActivities   AttendanceActivity[]
  auctionMatches         AuctionMatch[]
  clientsOwned           Client[] @relation("ClientOwner")



  @@map("users")

}



model Tenant {

  id                String   @id @default(uuid()) @db.Uuid

  slug              String   @unique

  name              String

  storageQuotaBytes BigInt   @default(10737418240) @map("storage_quota_bytes")

  createdAt         DateTime @default(now()) @map("created_at")

  updatedAt         DateTime @updatedAt @map("updated_at")



  members         TenantMember[]

  documents       Document[]

  uploadSessions  UploadSession[]

  clients         Client[]

  teams           Team[]

  collaborators      Collaborator[]

  clientProperties   ClientProperty[]

  clientFormTokens   ClientFormToken[]

  tenantIntentions   TenantIntention[]

  clientImportBatches ClientImportBatch[]

  clientExportBatches ClientExportBatch[]

  auditLogs           AuditLog[]

  auctions            Auction[]

  attendanceBoardColumns AttendanceBoardColumn[]
  attendanceActions      AttendanceAction[]



  @@map("tenants")

}



model TenantMember {

  tenantId  String     @map("tenant_id") @db.Uuid

  userId    String     @map("user_id") @db.Uuid

  role      TenantRole @default(member)

  joinedAt  DateTime   @default(now()) @map("joined_at")



  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@id([tenantId, userId])

  @@index([userId])

  @@map("tenant_members")

}



model Team {

  id          String   @id @default(uuid()) @db.Uuid

  tenantId    String   @map("tenant_id") @db.Uuid

  name        String

  description String?

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")

  deletedAt   DateTime? @map("deleted_at")



  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  collaborators Collaborator[]



  @@index([tenantId, name])

  @@map("teams")

}



model Collaborator {

  id        String   @id @default(uuid()) @db.Uuid

  tenantId  String   @map("tenant_id") @db.Uuid

  teamId    String   @map("team_id") @db.Uuid

  userId    String?  @map("user_id") @db.Uuid

  name      String

  email     String?

  phone     String?

  role      String?

  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  deletedAt DateTime? @map("deleted_at")



  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  responsibleClients Client[] @relation("ClientResponsible")



  @@index([tenantId, teamId])

  @@index([tenantId, name])

  @@map("collaborators")

}



model Client {

  id             String   @id @default(uuid()) @db.Uuid

  tenantId       String   @map("tenant_id") @db.Uuid

  ownerId        String?  @map("owner_id") @db.Uuid

  responsibleId  String?  @map("responsible_id") @db.Uuid

  name           String

  document       String?

  legacyCode     String?  @map("legacy_code")

  email          String?

  phone          String?

  addressFull    String?  @map("address_full")

  notes          String?

  animalType         String?  @map("animal_type")

  animalSex          String?  @map("animal_sex")

  livestockCategory  String?  @map("livestock_category")

  intentionNotes     String?  @map("intention_notes")

  attendanceStage       String?   @map("attendance_stage")
  attendanceChecklist   String[]  @default([]) @map("attendance_checklist")
  attendanceFinalizedAt DateTime? @map("attendance_finalized_at")
  attendanceUpdatedAt   DateTime? @map("attendance_updated_at")

  active         Boolean  @default(true)

  isDefault      Boolean  @default(false) @map("is_default")

  createdAt      DateTime @default(now()) @map("created_at")

  updatedAt      DateTime @updatedAt @map("updated_at")

  deletedAt      DateTime? @map("deleted_at")



  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  owner             User?              @relation("ClientOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  responsible       Collaborator?      @relation("ClientResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  documents         Document[]

  properties        ClientProperty[]

  clientFormTokens  ClientFormToken[]

  intentions        ClientIntention[]

  auctionMatches    AuctionMatch[]

  attendanceActions AttendanceAction[]



  @@index([tenantId, name])

  @@index([tenantId, ownerId])

  @@index([tenantId, document])

  @@index([tenantId, legacyCode])

  @@index([tenantId, animalType])

  @@index([tenantId, animalSex])

  @@index([tenantId, livestockCategory])

  @@index([tenantId, attendanceStage])

  @@index([tenantId, deletedAt])

  @@map("clients")

}



model ClientProperty {

  id         String   @id @default(uuid()) @db.Uuid

  clientId   String   @map("client_id") @db.Uuid

  tenantId   String   @map("tenant_id") @db.Uuid

  farmName   String   @map("farm_name")

  city       String

  state      String

  routeNotes String?  @map("route_notes")

  phone      String?

  ie         String?

  nirf       String?

  sortOrder  Int      @default(0) @map("sort_order")

  createdAt  DateTime @default(now()) @map("created_at")

  updatedAt  DateTime @updatedAt @map("updated_at")



  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)



  @@index([clientId, sortOrder])

  @@index([tenantId])

  @@index([tenantId, state])

  @@map("client_properties")

}



model ClientFormToken {

  id          String               @id @default(uuid()) @db.Uuid

  tenantId    String               @map("tenant_id") @db.Uuid

  type        ClientFormTokenType

  clientId    String?              @map("client_id") @db.Uuid

  tokenHash   String               @unique @map("token_hash")

  expiresAt   DateTime             @map("expires_at")

  usedAt      DateTime?            @map("used_at")

  submittedAt DateTime?            @map("submitted_at")

  revokedAt   DateTime?            @map("revoked_at")

  createdById String               @map("created_by") @db.Uuid

  createdAt   DateTime             @default(now()) @map("created_at")



  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdBy User    @relation(fields: [createdById], references: [id])



  @@index([tenantId, type])

  @@index([clientId])

  @@map("client_form_tokens")

}



model Document {

  id           String         @id @default(uuid()) @db.Uuid

  tenantId     String         @map("tenant_id") @db.Uuid

  clientId     String         @map("client_id") @db.Uuid

  createdById  String         @map("created_by") @db.Uuid

  name         String

  mimeType     String         @map("mime_type")

  sizeBytes    BigInt?        @map("size_bytes")

  gcsBucket    String         @map("gcs_bucket")

  gcsObjectKey String         @map("gcs_object_key")

  status       DocumentStatus @default(draft)

  checksum     String?

  createdAt    DateTime       @default(now()) @map("created_at")

  updatedAt    DateTime       @updatedAt @map("updated_at")

  deletedAt    DateTime?      @map("deleted_at")



  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdBy      User            @relation(fields: [createdById], references: [id])

  uploadSessions UploadSession[]



  @@index([tenantId, createdAt(sort: Desc)])

  @@index([tenantId, status])

  @@index([tenantId, clientId])

  @@map("documents")

}



model UploadSession {

  id           String   @id @default(uuid()) @db.Uuid

  documentId   String   @map("document_id") @db.Uuid

  tenantId     String   @map("tenant_id") @db.Uuid

  expiresAt    DateTime @map("expires_at")

  expectedSize BigInt   @map("expected_size")

  contentType  String   @map("content_type")

  createdAt    DateTime @default(now()) @map("created_at")



  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)



  @@map("upload_sessions")

}



model TenantIntention {

  id        String   @id @default(uuid()) @db.Uuid

  tenantId  String   @map("tenant_id") @db.Uuid

  code      String

  label     String

  sortOrder Int      @default(0) @map("sort_order")

  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clients ClientIntention[]



  @@unique([tenantId, code])

  @@index([tenantId, sortOrder])

  @@map("tenant_intentions")

}



model ClientIntention {

  clientId    String @map("client_id") @db.Uuid

  intentionId String @map("intention_id") @db.Uuid



  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  intention TenantIntention @relation(fields: [intentionId], references: [id], onDelete: Cascade)



  @@id([clientId, intentionId])

  @@index([intentionId])

  @@map("client_intentions")

}



model ClientImportBatch {

  id             String   @id @default(uuid()) @db.Uuid

  tenantId       String   @map("tenant_id") @db.Uuid

  createdById    String   @map("created_by") @db.Uuid

  fileName       String   @map("file_name")

  mimeType       String   @map("mime_type")

  sourceType     String   @map("source_type")

  rowCount       Int      @map("row_count")

  importedCount  Int      @default(0) @map("imported_count")

  updatedCount   Int      @default(0) @map("updated_count")

  skippedCount   Int      @default(0) @map("skipped_count")

  createdAt      DateTime @default(now()) @map("created_at")



  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdBy User   @relation(fields: [createdById], references: [id])



  @@index([tenantId, createdAt(sort: Desc)])

  @@map("client_import_batches")

}



model ClientExportBatch {

  id            String               @id @default(uuid()) @db.Uuid

  tenantId      String               @map("tenant_id") @db.Uuid

  createdById   String               @map("created_by") @db.Uuid

  purpose       ClientExportPurpose

  destination   String?

  recipientName String?              @map("recipient_name")

  notes         String?

  clientCount   Int                  @map("client_count")

  filters       Json?

  createdAt     DateTime             @default(now()) @map("created_at")



  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdBy User   @relation(fields: [createdById], references: [id])



  @@index([tenantId, createdAt(sort: Desc)])

  @@index([tenantId, purpose])

  @@map("client_export_batches")

}



model AuditLog {

  id          String   @id @default(uuid()) @db.Uuid

  tenantId    String?  @map("tenant_id") @db.Uuid

  userId      String?  @map("user_id") @db.Uuid

  actorEmail  String?  @map("actor_email")

  action      String

  entityType  String?  @map("entity_type")

  entityId    String?  @map("entity_id")

  summary     String?

  metadata    Json?

  ip          String?

  userAgent   String?  @map("user_agent")

  createdAt   DateTime @default(now()) @map("created_at")



  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)



  @@index([createdAt(sort: Desc)])

  @@index([tenantId, createdAt(sort: Desc)])

  @@index([action])

  @@index([userId])

  @@map("audit_logs")

}



model BrazilianCity {

  id             Int    @id

  name           String

  state          String @db.Char(2)

  normalizedName String @map("normalized_name")

  latitude       Float?

  longitude      Float?



  @@unique([normalizedName, state])

  @@index([state])

  @@map("brazilian_cities")

}



model Auction {

  id                  String    @id @default(uuid()) @db.Uuid

  tenantId            String    @map("tenant_id") @db.Uuid

  name                String

  scheduledAt         DateTime? @map("scheduled_at")

  location            String?

  status              String    @default("agendado")

  animalType          String?   @map("animal_type")

  animalSex           String?   @map("animal_sex")

  livestockCategories String[]  @default([]) @map("livestock_categories")

  targetIntentionCode String?   @map("target_intention_code")

  offersNotes         String?   @map("offers_notes")

  isBulaRemates       Boolean   @default(false) @map("is_bula_remates")

  active              Boolean   @default(true)

  source              String    @default("manual")

  externalKey         String?   @map("external_key")

  createdAt           DateTime  @default(now()) @map("created_at")

  updatedAt           DateTime  @updatedAt @map("updated_at")

  deletedAt           DateTime? @map("deleted_at")



  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  matches AuctionMatch[]

  attendanceActions AttendanceAction[]



  @@index([tenantId, scheduledAt])

  @@index([tenantId, status])

  @@index([tenantId, deletedAt])

  @@unique([tenantId, externalKey])

  @@map("auctions")

}



model AuctionMatch {

  auctionId String   @map("auction_id") @db.Uuid

  clientId  String   @map("client_id") @db.Uuid

  ownerId   String   @map("owner_id") @db.Uuid

  status    String

  source    String   @default("manual")

  notes     String?

  createdAt DateTime @default(now()) @map("created_at")



  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)



  @@id([auctionId, clientId, ownerId])

  @@index([clientId])

  @@index([ownerId])

  @@map("auction_matches")

}



model AttendanceBoardColumn {

  id        String   @id @default(uuid()) @db.Uuid

  tenantId  String   @map("tenant_id") @db.Uuid

  ownerId   String   @map("owner_id") @db.Uuid

  title     String

  color     String?

  sortOrder Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  deletedAt DateTime? @map("deleted_at")



  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  actions AttendanceAction[]



  @@index([tenantId, ownerId, sortOrder])

  @@map("attendance_board_columns")

}



model AttendanceAction {

  id          String    @id @default(uuid()) @db.Uuid

  tenantId    String    @map("tenant_id") @db.Uuid

  ownerId     String    @map("owner_id") @db.Uuid

  columnId    String    @map("column_id") @db.Uuid

  clientId    String    @map("client_id") @db.Uuid

  auctionId   String?   @map("auction_id") @db.Uuid

  title       String

  description String?

  status      String    @default("open")

  sortOrder   Int       @default(0) @map("sort_order")

  dueDate     DateTime? @map("due_date")

  completedAt DateTime? @map("completed_at")

  createdAt   DateTime  @default(now()) @map("created_at")

  updatedAt   DateTime  @updatedAt @map("updated_at")

  deletedAt   DateTime? @map("deleted_at")



  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  owner     User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  column    AttendanceBoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  client    Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  auction   Auction?              @relation(fields: [auctionId], references: [id], onDelete: SetNull)

  tasks     AttendanceActionTask[]

  activities AttendanceActivity[]



  @@index([tenantId, ownerId, columnId, sortOrder])

  @@index([clientId])

  @@index([auctionId])

  @@map("attendance_actions")

}



model AttendanceActionTask {

  id        String    @id @default(uuid()) @db.Uuid

  actionId  String    @map("action_id") @db.Uuid

  title     String

  done      Boolean   @default(false)

  sortOrder Int       @default(0) @map("sort_order")

  dueDate   DateTime? @map("due_date")

  createdAt DateTime  @default(now()) @map("created_at")

  updatedAt DateTime  @updatedAt @map("updated_at")



  action AttendanceAction @relation(fields: [actionId], references: [id], onDelete: Cascade)



  @@index([actionId, sortOrder])

  @@map("attendance_action_tasks")

}



model AttendanceActivity {

  id        String   @id @default(uuid()) @db.Uuid

  actionId  String   @map("action_id") @db.Uuid

  authorId  String?  @map("author_id") @db.Uuid

  type      String

  content   String

  createdAt DateTime @default(now()) @map("created_at")



  action AttendanceAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  author User?            @relation(fields: [authorId], references: [id], onDelete: SetNull)



  @@index([actionId, createdAt(sort: Desc)])

  @@map("attendance_activities")

}


