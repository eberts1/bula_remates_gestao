generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}



enum TenantRole {

  owner

  admin

  member

  viewer

}



enum DocumentStatus {

  draft

  ready

  deleted

}



enum ClientFormTokenType {

  create

  edit

}



model User {

  id           String   @id @default(uuid()) @db.Uuid

  email        String   @unique

  passwordHash String   @map("password_hash")

  name         String

  createdAt    DateTime @default(now()) @map("created_at")

  updatedAt    DateTime @updatedAt @map("updated_at")

  deletedAt    DateTime? @map("deleted_at")



  memberships    TenantMember[]

  documents         Document[]

  collaborators     Collaborator[]

  clientFormTokens  ClientFormToken[]

  clientImportBatches ClientImportBatch[]



  @@map("users")

}



model Tenant {

  id                String   @id @default(uuid()) @db.Uuid

  slug              String   @unique

  name              String

  storageQuotaBytes BigInt   @default(10737418240) @map("storage_quota_bytes")

  createdAt         DateTime @default(now()) @map("created_at")

  updatedAt         DateTime @updatedAt @map("updated_at")



  members         TenantMember[]

  documents       Document[]

  uploadSessions  UploadSession[]

  clients         Client[]

  teams           Team[]

  collaborators      Collaborator[]

  clientProperties   ClientProperty[]

  clientFormTokens   ClientFormToken[]

  tenantIntentions   TenantIntention[]

  clientImportBatches ClientImportBatch[]



  @@map("tenants")

}



model TenantMember {

  tenantId  String     @map("tenant_id") @db.Uuid

  userId    String     @map("user_id") @db.Uuid

  role      TenantRole @default(member)

  joinedAt  DateTime   @default(now()) @map("joined_at")



  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@id([tenantId, userId])

  @@map("tenant_members")

}



model Team {

  id          String   @id @default(uuid()) @db.Uuid

  tenantId    String   @map("tenant_id") @db.Uuid

  name        String

  description String?

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")

  deletedAt   DateTime? @map("deleted_at")



  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  collaborators Collaborator[]



  @@index([tenantId, name])

  @@map("teams")

}



model Collaborator {

  id        String   @id @default(uuid()) @db.Uuid

  tenantId  String   @map("tenant_id") @db.Uuid

  teamId    String   @map("team_id") @db.Uuid

  userId    String?  @map("user_id") @db.Uuid

  name      String

  email     String?

  phone     String?

  role      String?

  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  deletedAt DateTime? @map("deleted_at")



  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  responsibleClients Client[] @relation("ClientResponsible")



  @@index([tenantId, teamId])

  @@index([tenantId, name])

  @@map("collaborators")

}



model Client {

  id             String   @id @default(uuid()) @db.Uuid

  tenantId       String   @map("tenant_id") @db.Uuid

  responsibleId  String?  @map("responsible_id") @db.Uuid

  name           String

  document       String?

  email          String?

  phone          String?

  addressFull    String?  @map("address_full")

  notes          String?

  animalType         String?  @map("animal_type")

  animalSex          String?  @map("animal_sex")

  livestockCategory  String?  @map("livestock_category")

  intentionNotes     String?  @map("intention_notes")

  active         Boolean  @default(true)

  isDefault      Boolean  @default(false) @map("is_default")

  createdAt      DateTime @default(now()) @map("created_at")

  updatedAt      DateTime @updatedAt @map("updated_at")

  deletedAt      DateTime? @map("deleted_at")



  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  responsible       Collaborator?      @relation("ClientResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)

  documents         Document[]

  properties        ClientProperty[]

  clientFormTokens  ClientFormToken[]

  intentions        ClientIntention[]



  @@index([tenantId, name])

  @@index([tenantId, document])

  @@index([tenantId, animalType])

  @@index([tenantId, animalSex])

  @@index([tenantId, livestockCategory])

  @@map("clients")

}



model ClientProperty {

  id         String   @id @default(uuid()) @db.Uuid

  clientId   String   @map("client_id") @db.Uuid

  tenantId   String   @map("tenant_id") @db.Uuid

  farmName   String   @map("farm_name")

  city       String

  state      String

  routeNotes String?  @map("route_notes")

  phone      String?

  ie         String?

  nirf       String?

  sortOrder  Int      @default(0) @map("sort_order")

  createdAt  DateTime @default(now()) @map("created_at")

  updatedAt  DateTime @updatedAt @map("updated_at")



  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)



  @@index([clientId, sortOrder])

  @@index([tenantId])

  @@map("client_properties")

}



model ClientFormToken {

  id          String               @id @default(uuid()) @db.Uuid

  tenantId    String               @map("tenant_id") @db.Uuid

  type        ClientFormTokenType

  clientId    String?              @map("client_id") @db.Uuid

  tokenHash   String               @unique @map("token_hash")

  expiresAt   DateTime             @map("expires_at")

  usedAt      DateTime?            @map("used_at")

  submittedAt DateTime?            @map("submitted_at")

  revokedAt   DateTime?            @map("revoked_at")

  createdById String               @map("created_by") @db.Uuid

  createdAt   DateTime             @default(now()) @map("created_at")



  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdBy User    @relation(fields: [createdById], references: [id])



  @@index([tenantId, type])

  @@index([clientId])

  @@map("client_form_tokens")

}



model Document {

  id           String         @id @default(uuid()) @db.Uuid

  tenantId     String         @map("tenant_id") @db.Uuid

  clientId     String         @map("client_id") @db.Uuid

  createdById  String         @map("created_by") @db.Uuid

  name         String

  mimeType     String         @map("mime_type")

  sizeBytes    BigInt?        @map("size_bytes")

  gcsBucket    String         @map("gcs_bucket")

  gcsObjectKey String         @map("gcs_object_key")

  status       DocumentStatus @default(draft)

  checksum     String?

  createdAt    DateTime       @default(now()) @map("created_at")

  updatedAt    DateTime       @updatedAt @map("updated_at")

  deletedAt    DateTime?      @map("deleted_at")



  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdBy      User            @relation(fields: [createdById], references: [id])

  uploadSessions UploadSession[]



  @@index([tenantId, createdAt(sort: Desc)])

  @@index([tenantId, status])

  @@index([tenantId, clientId])

  @@map("documents")

}



model UploadSession {

  id           String   @id @default(uuid()) @db.Uuid

  documentId   String   @map("document_id") @db.Uuid

  tenantId     String   @map("tenant_id") @db.Uuid

  expiresAt    DateTime @map("expires_at")

  expectedSize BigInt   @map("expected_size")

  contentType  String   @map("content_type")

  createdAt    DateTime @default(now()) @map("created_at")



  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)



  @@map("upload_sessions")

}



model TenantIntention {

  id        String   @id @default(uuid()) @db.Uuid

  tenantId  String   @map("tenant_id") @db.Uuid

  code      String

  label     String

  sortOrder Int      @default(0) @map("sort_order")

  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  tenant  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clients ClientIntention[]



  @@unique([tenantId, code])

  @@index([tenantId, sortOrder])

  @@map("tenant_intentions")

}



model ClientIntention {

  clientId    String @map("client_id") @db.Uuid

  intentionId String @map("intention_id") @db.Uuid



  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  intention TenantIntention @relation(fields: [intentionId], references: [id], onDelete: Cascade)



  @@id([clientId, intentionId])

  @@map("client_intentions")

}



model ClientImportBatch {

  id             String   @id @default(uuid()) @db.Uuid

  tenantId       String   @map("tenant_id") @db.Uuid

  createdById    String   @map("created_by") @db.Uuid

  fileName       String   @map("file_name")

  mimeType       String   @map("mime_type")

  sourceType     String   @map("source_type")

  rowCount       Int      @map("row_count")

  importedCount  Int      @default(0) @map("imported_count")

  updatedCount   Int      @default(0) @map("updated_count")

  skippedCount   Int      @default(0) @map("skipped_count")

  createdAt      DateTime @default(now()) @map("created_at")



  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdBy User   @relation(fields: [createdById], references: [id])



  @@index([tenantId, createdAt(sort: Desc)])

  @@map("client_import_batches")

}


