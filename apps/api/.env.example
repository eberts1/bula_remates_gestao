DATABASE_URL="postgresql://docs:docs_secret@localhost:5433/docs_bula?schema=public"
REDIS_URL="redis://localhost:6379"

PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_TTL_SECONDS=604800

# local = armazenamento em disco (dev) | gcs = Google Cloud Storage
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./uploads

# Produção com GCS (bucket: bula_remates_gestao):
# STORAGE_MODE=gcs
# GCS_BUCKET=bula_remates_gestao
# GCS_PROJECT_ID=seu-projeto-gcp-id
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}   # Railway: JSON em uma linha
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json     # local: caminho do arquivo
